# Point the chat at the admin backend (server/). Leave empty to run the
# static site with no backend (lead capture + admin console stay dormant).
VITE_API_URL=http://localhost:4000

# ─── Live AI chat (Gemini) ─────────────────────────────────────────────
# These power /api/chat (a Vercel serverless function in /api). Set them in
# Vercel → Project → Settings → Environment Variables. The key is SERVER-SIDE
# only — it must NOT be prefixed with VITE_ (those get bundled into public JS).
#
#   GEMINI_API_KEY   required   free key from https://aistudio.google.com/apikey
#   GEMINI_MODEL     optional   defaults to gemini-2.5-flash
#
# Optional: override the endpoint the frontend calls (defaults to same-origin
# /api/chat). Useful only for local testing against a deployed function.
# VITE_AI_URL=https://chatwith.yasirbashir.com/api/chat
