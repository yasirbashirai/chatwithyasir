# Copy to .env and fill in real values.
PORT=4000

# Sign-in for Yasir (admin). Only this email can ever log in.
ADMIN_EMAIL=yasirbashirai@gmail.com

# For production, generate a hash: `npm run hash "your-password"` and use it here:
# ADMIN_PASSWORD_HASH=$2a$10$....
# For local dev you can use a plain password instead:
ADMIN_PASSWORD=changeme

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=please-change-this-to-a-long-random-string
