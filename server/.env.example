# ─── chatwithyasir live server ───────────────────────────────────────────
# Copy to .env and fill in. On Render, set these as Environment Variables.

# Port (Render sets this automatically; 4000 for local dev)
PORT=4000

# Durable storage — Neon Postgres connection string (free at neon.tech).
# Looks like: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Admin login (Yasir only)
ADMIN_EMAIL=yasirbashirai@gmail.com
# Recommended: a bcrypt hash from `npm run hash "your-password"`
ADMIN_PASSWORD_HASH=
# Dev-only fallback if no hash is set:
ADMIN_PASSWORD=changeme
# Secret used to sign admin login tokens — use a long random string in prod.
JWT_SECRET=change-me-to-a-long-random-string

# Email alerts (Gmail App Password — NOT your normal password)
# Enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_USER=yasirbashirai@gmail.com
SMTP_PASS=
# Where alerts are delivered (defaults to SMTP_USER)
NOTIFY_EMAIL=yasirbashirai@gmail.com

# Base URL of the live site, used in the "join" link inside alert emails.
ADMIN_URL=https://chatwith.yasirbashir.com

# CORS allowlist (comma-separated). Leave empty in local dev to allow all.
ALLOWED_ORIGINS=https://chatwith.yasirbashir.com
